#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/mouse.h> // Indispensable pour la souris

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp A      &kp Z      &kp E      &kp R
                &mkp LCLK  &mkp RCLK  &mo 1      &kp SPACE
            >;
        };
    };
};
